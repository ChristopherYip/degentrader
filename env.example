# Copy this file's variable names into Railway's Variables tab.
# Do NOT put real values in this file or commit it with real secrets.

ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
X_API_KEY=xxxxxxxxxxxxxxxxxxxx
X_API_SECRET=xxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxx
X_ACCESS_SECRET=xxxxxxxxxxxxxxxxxxxx

# Optional - set differently per Railway service for different time slots
POST_TYPE=mixed
DIFFICULTY=medium
TONE=engaging
ACCOUNT_HANDLE=DailyBrainDrop
DRY_RUN=false
